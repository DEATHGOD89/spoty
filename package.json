{
  "name": "spoty",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:build": "vite build && electron-builder --win",
    "desktop:package": "electron-builder --win --dir"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "firebase": "^12.14.0",
    "jsmediatags": "^3.9.7",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.3.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.spoty.player",
    "productName": "Spoty",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo512.png"
    }
  }
}
